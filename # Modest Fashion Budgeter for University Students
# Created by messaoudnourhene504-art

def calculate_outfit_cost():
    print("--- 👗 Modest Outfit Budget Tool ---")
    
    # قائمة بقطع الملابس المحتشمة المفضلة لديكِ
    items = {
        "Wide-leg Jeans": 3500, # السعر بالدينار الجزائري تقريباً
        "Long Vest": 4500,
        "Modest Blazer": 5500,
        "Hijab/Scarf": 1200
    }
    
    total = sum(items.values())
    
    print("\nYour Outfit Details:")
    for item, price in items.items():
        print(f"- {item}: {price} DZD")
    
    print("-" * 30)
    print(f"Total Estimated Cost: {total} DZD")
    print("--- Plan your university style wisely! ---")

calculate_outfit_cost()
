def calculate_outfit_cost():
    print("--- 👗 Modest Outfit Budget Tool ---")
    
    # قائمة بقطع الملابس المحتشمة المفضلة لديكِ
    items = {
        "Wide-leg Jeans": 3500, # السعر بالدينار الجزائري تقريباً
        "Long Vest": 4500,
        "Modest Blazer": 5500,
        "Hijab/Scarf": 1200
    }
    
    total = sum(items.values())
    
    print("\nYour Outfit Details:")
    for item, price in items.items():
        print(f"- {item}: {price} DZD")
    
    print("-" * 30)
    print(f"Total Estimated Cost: {total} DZD")
    print("--- Plan your university style wisely! ---")

calculate_outfit_cost()
